# PostgreSQL connection used by Prisma. Use a dedicated database per environment.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/fekitech_builder?schema=public"

# Better Auth. Generate a long random value for the secret.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_ENV="development"
AUTH_TRUSTED_ORIGINS="http://localhost:3000"
AUTH_REQUIRE_EMAIL_VERIFICATION="false"
RATE_LIMIT_KEY_SECRET=""
TRUSTED_CLIENT_IP_HEADER="x-forwarded-for"

# Required for password recovery and for email verification in production.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="FekiTech Builder <no-reply@example.com>"

# Temporary plan testing. This is always disabled when NODE_ENV=production.
PLAN_TEST_MODE_ENABLED="false"
PLAN_TEST_ADMIN_EMAILS=""
ALLOW_TEST_ADMIN_BOOTSTRAP="false"
TEST_ADMIN_EMAIL=""

# Tenant routing.
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
ROOT_DOMAIN="localhost:3000"

# Upload storage. Local storage is accepted only outside production.
UPLOAD_STORAGE_DRIVER="local"
UPLOAD_LOCAL_DIRECTORY=".data/uploads"
S3_BUCKET=""
S3_REGION=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"

# HMAC key used to store custom-domain verification challenges safely.
DOMAIN_VERIFICATION_SECRET=""
DOMAIN_VERIFICATION_BYPASS_ENABLED="false"
