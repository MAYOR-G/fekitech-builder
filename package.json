{
  "name": "fekitech-builder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && prisma migrate deploy && next build --webpack",
    "start": "next start",
    "lint": "eslint src next.config.ts --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "admin:grant-test": "node scripts/grant-test-admin.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.848.0",
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "6.19.3",
    "@tanstack/react-query": "^5.101.2",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^0.471.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "typescript": "5.8.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
